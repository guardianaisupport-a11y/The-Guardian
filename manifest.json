{
  "manifest_version": 3,
  "name": "The Guardian",
  "version": "1.0",
  "description": "AI-powered browser assistant for misinformation, privacy, and safety awareness",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "http://localhost:8090/*",
    "http://127.0.0.1:8090/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content-styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "The Guardian"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "onboarding.html",
        "safe-preview.html",
        "safe-preview.css",
        "safe-preview.js",
        "icons/logov.jpeg"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}